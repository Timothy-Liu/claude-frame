{
  "name": "claude-frame",
  "displayName": "Claude Frame",
  "description": "Interactive full-tab chat panel for Claude Code with tmux persistence and per-session branding.",
  "version": "0.1.1",
  "publisher": "Timothy-Liu",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Timothy-Liu/claude-frame.git"
  },
  "homepage": "https://github.com/Timothy-Liu/claude-frame#readme",
  "bugs": {
    "url": "https://github.com/Timothy-Liu/claude-frame/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "chat",
    "agent",
    "tmux",
    "coding-assistant"
  ],
  "activationEvents": [
    "onCommand:claude-frame.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-frame.openChat",
        "title": "Claude Frame: Open"
      }
    ],
    "keybindings": [
      {
        "command": "claude-frame.openChat",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src test --ext .ts",
    "test:unit": "mocha -r ts-node/register 'test/unit/**/*.test.ts'",
    "test:integration": "tsc -p tsconfig.test.json && node ./out/test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.24.0",
    "chai": "^4.4.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "marked": "^12.0.0",
    "mocha": "^10.3.0",
    "prismjs": "^1.29.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
